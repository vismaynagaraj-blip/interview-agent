# ═══════════════════════════════════════════════════════════════════════════════
#  AI Interview Training Agent — Environment Configuration
#  COPY THIS FILE TO .env AND FILL IN YOUR VALUES
#  NEVER COMMIT .env TO GIT — it is already in .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ─── IBM watsonx.ai Credentials (REQUIRED for AI features) ───────────────────
# Get yours at: https://cloud.ibm.com/iam/apikeys
IBM_WATSONX_API_KEY=oTyRnIZx_6PN80u10OqKQOQ-xabUsgL4F69DKE4u9R65

# Create a watsonx.ai project at: https://dataplatform.cloud.ibm.com
IBM_WATSONX_PROJECT_ID=85442967-1d2f-4b9f-a018-e7333b9f25e6
# watsonx.ai endpoint (choose your region)
# US South  : https://us-south.ml.cloud.ibm.com
# EU DE     : https://eu-de.ml.cloud.ibm.com
# EU GB     : https://eu-gb.ml.cloud.ibm.com
# JP Tokyo  : https://jp-tok.ml.cloud.ibm.com
IBM_WATSONX_URL=https://au-syd.ml.cloud.ibm.com
# ─── Model Selection ─────────────────────────────────────────────────────────
# Available IBM Granite models (as of 2024):
#   ibm/granite-13b-instruct-v2      ← Recommended (best balance)
#   ibm/granite-7b-instruct          ← Faster, lighter
#   ibm/granite-20b-multilingual     ← Multilingual support
#   ibm/granite-34b-code-instruct    ← Best for technical/coding questions
WATSONX_MODEL_ID=ibm/granite-13b-instruct-v2

# ─── Model Parameters (tune to adjust response quality) ──────────────────────
# Temperature: 0.0 (deterministic) → 1.0 (creative). Default: 0.7
WATSONX_TEMPERATURE=0.7

# Top-p nucleus sampling. Default: 0.9
WATSONX_TOP_P=0.9

# Top-k sampling. Default: 50
WATSONX_TOP_K=50

# ─── Flask Security ───────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change_this_to_a_secure_random_string_minimum_32_chars

# ─── Flask Environment ────────────────────────────────────────────────────────
# Set to "true" for hot-reload during development. NEVER "true" in production.
FLASK_DEBUG=false

# Application port
PORT=5000

# ─── CORS (production) ────────────────────────────────────────────────────────
# Comma-separated allowed origins. Use * for development only.
# Example: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=*
